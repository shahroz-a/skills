{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shahroz-a/skills/schema/registry.schema.json",
  "title": "UI Grids Skills Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "skills"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skill" }
    }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "path",
        "checksum",
        "version",
        "origin",
        "license",
        "author",
        "maintainer",
        "releasedAt",
        "reviewedAt",
        "nextReviewAt",
        "testedAgents",
        "safetyLevel",
        "source",
        "fixtureCount",
        "lastPassingCommit"
      ],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "description": { "type": "string", "minLength": 20, "maxLength": 1024 },
        "path": { "type": "string", "pattern": "^skills/[a-z0-9-]+$" },
        "checksum": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "origin": { "enum": ["uigrids", "external", "adapted"] },
        "license": { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 },
        "maintainer": { "type": "string", "minLength": 1 },
        "releasedAt": { "type": "string", "format": "date" },
        "reviewedAt": { "type": "string", "format": "date" },
        "nextReviewAt": { "type": "string", "format": "date" },
        "testedAgents": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "safetyLevel": { "enum": ["read-only", "writes-workspace", "network", "account", "destructive"] },
        "source": { "type": "string", "minLength": 1 },
        "fixtureCount": { "type": "integer", "minimum": 6 },
        "lastPassingCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
      }
    }
  }
}
